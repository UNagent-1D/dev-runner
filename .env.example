# Copy to .env and fill in. All vars here are consumed by docker-compose.yml.

# -----------------------------------------------------------------------------
# OpenRouter (used in place of OpenAI by chat-orch and conversation-chat).
# The services read OPENAI_API_KEY internally — compose injects this value
# there and overrides OPENAI_BASE_URL to point at OpenRouter.
# Get a key at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# -----------------------------------------------------------------------------
# JWT signing secret for Tenant Service (login handler).
# -----------------------------------------------------------------------------
JWT_SECRET=dev-change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Supabase Postgres (hosted). Replace YOUR-PASSWORD with the real one.
# sslmode=require is mandatory — Supabase rejects plaintext connections.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.xxizwqfqpiscfhsnadme.supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# MongoDB Atlas (hosted). Paste the SRV URI from the Atlas "Connect" dialog.
# -----------------------------------------------------------------------------
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=conversatory

# -----------------------------------------------------------------------------
# Frontend — base URL for the Metricas KPI API (defaults to http://localhost:8091).
# Uncomment and override if the frontend is served from a different host.
# -----------------------------------------------------------------------------
# VITE_METRICAS_API_URL=http://localhost:8091

# -----------------------------------------------------------------------------
# Frontend — base URL for the chat orchestrator (defaults to http://localhost:8000).
# -----------------------------------------------------------------------------
# VITE_ORCH_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Telegram long-poll integration (leave empty to disable the bot channel).
# Get a token from @BotFather. The orch still runs without these.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=demo-tenant
