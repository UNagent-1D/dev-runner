# Copy to .env and fill in. All vars here are consumed by docker-compose.yml.

# -----------------------------------------------------------------------------
# OpenRouter (used in place of OpenAI by chat-orch and conversation-chat).
# The services read OPENAI_API_KEY internally — compose injects this value
# there and overrides OPENAI_BASE_URL to point at OpenRouter.
# Get a key at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# -----------------------------------------------------------------------------
# JWT signing secret for Tenant Service (login handler).
# -----------------------------------------------------------------------------
JWT_SECRET=dev-change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Supabase Postgres (hosted). Replace YOUR-PASSWORD with the real one.
# sslmode=require is mandatory — Supabase rejects plaintext connections.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.xxizwqfqpiscfhsnadme.supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# MongoDB Atlas (hosted). Paste the SRV URI from the Atlas "Connect" dialog.
# -----------------------------------------------------------------------------
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=conversatory

# -----------------------------------------------------------------------------
# LLM model + endpoint (OpenRouter-compatible). Both are optional — compose
# falls back to the defaults shown below. Override here to swap models or
# point at a self-hosted gateway.
# -----------------------------------------------------------------------------
# OPENAI_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# Frontend — Vite inlines these at *build* time (compose passes them as
# build.args). Override only if the dashboard is served from a host where
# `localhost` does not resolve to the compose ports.
# -----------------------------------------------------------------------------
# VITE_TENANT_API_URL=http://localhost:8080
# VITE_ORCH_API_URL=http://localhost:8000
# VITE_METRICAS_API_URL=http://localhost:8091
# VITE_CHAT_API_URL=http://localhost:8082/api/v1

# -----------------------------------------------------------------------------
# Telegram long-poll integration (leave empty to disable the bot channel).
# Get a token from @BotFather. The orch still runs without these.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=demo-tenant

# -----------------------------------------------------------------------------
# Twilio voice channel (out of scope today — see AGENTS.md §11). Leave empty
# to disable. Generate the credentials in the Twilio Console:
#   • Account SID + Auth Token   → Console → Account → API keys & tokens
#   • API Key SID + Secret       → Console → Account → API keys & tokens
#                                  → Create API Key (use a Standard key, copy
#                                  the secret immediately — it shows once).
#   • TwiML App SID              → Console → Voice → TwiML → TwiML Apps
#                                  → Create new TwiML App.
# Account SID + Auth Token are enough for REST calls. API Key + Secret are
# required to sign Access Tokens (JWTs) for the @twilio/voice-sdk client.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_TENANT_ID=demo-tenant

# -----------------------------------------------------------------------------
# Compliance service. Audit logs land in the local email-mongo container by
# default; point MONGO_URI_COMPLIANCE at Atlas (or another host) to override.
# -----------------------------------------------------------------------------
# MONGO_URI_COMPLIANCE=mongodb://email-mongo:27017
# MONGO_DB_COMPLIANCE=UN_compliance_db

# -----------------------------------------------------------------------------
# Hospital-MP local Postgres. Schema + seed are baked in via the
# hospital-postgres container's init scripts. These defaults match the
# in-tree fixture credentials — change them for any environment that's
# reachable from the public internet.
# -----------------------------------------------------------------------------
# HOSPITAL_DB_NAME=hospital
# HOSPITAL_DB_USER=hospital
# HOSPITAL_DB_PASSWORD=hospital

# -----------------------------------------------------------------------------
# Email service (UN_email_send_ms). Stores audit rows in the local
# email-mongo container (not Atlas), so MONGO_URI here is unused by it.
# Leave SENDGRID_SANDBOX_MODE=true in dev to skip real delivery.
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.REPLACE_ME
SENDGRID_SANDBOX_MODE=true
EMAIL_FROM_DEFAULT=noreply@unagent.local
# EMAIL_FROM_NAME=UNAgent Notifications
# MONGO_DB_EMAIL=email_audit
# EMAIL_AUTH_STUB=true
