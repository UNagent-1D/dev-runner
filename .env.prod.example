# dev-runner — PROD environment values.
#
# Copy this file to `.env.prod` and fill in the placeholders. `.env.prod` is
# gitignored. The bootstrap script (`scripts/bootstrap.sh`) reads it and
# uploads every key as a Railway *shared variable* scoped to the `prod`
# environment.
#
# All hostnames are Railway-internal (`<service>.railway.internal`) — they
# resolve only inside Railway's private network for the `prod` env.
#
# IMPORTANT: every credential below must be different from `.env.dev` —
# never reuse dev secrets in prod.

# -----------------------------------------------------------------------------
# External APIs.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
SENDGRID_API_KEY=SG.REPLACE_ME
SENDGRID_SANDBOX_MODE=false

# -----------------------------------------------------------------------------
# Auth — fresh secret, not the dev one. Generate with `openssl rand -hex 48`.
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_FOR_PROD

# -----------------------------------------------------------------------------
# Data-store credentials. Generate fresh values with `openssl rand -hex 24`.
# Never reuse dev passwords.
# -----------------------------------------------------------------------------
TENANT_DB_USER=tenant
TENANT_DB_NAME=tenant
TENANT_DB_PASSWORD=REPLACE_WITH_RANDOM_STRING
HOSPITAL_DB_USER=hospital
HOSPITAL_DB_NAME=hospital
HOSPITAL_DB_PASSWORD=REPLACE_WITH_RANDOM_STRING
CONVERSATION_MONGO_USER=conversation
CONVERSATION_MONGO_PASSWORD=REPLACE_WITH_RANDOM_STRING
EMAIL_MONGO_USER=email
EMAIL_MONGO_PASSWORD=REPLACE_WITH_RANDOM_STRING

# -----------------------------------------------------------------------------
# Data-store DSNs.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://${TENANT_DB_USER}:${TENANT_DB_PASSWORD}@tenant-postgres.railway.internal:5432/${TENANT_DB_NAME}?sslmode=disable
MONGO_URI=mongodb://${CONVERSATION_MONGO_USER}:${CONVERSATION_MONGO_PASSWORD}@conversation-mongo.railway.internal:27017
MONGO_DB=conversatory
MONGO_URI_COMPLIANCE=mongodb://${EMAIL_MONGO_USER}:${EMAIL_MONGO_PASSWORD}@email-mongo.railway.internal:27017
MONGO_DB_COMPLIANCE=UN_compliance_db
MONGO_DB_EMAIL=email_audit
REDIS_URL=redis://redis.railway.internal:6379/1
RABBITMQ_URL=amqp://rabbitmq.railway.internal:5672

# -----------------------------------------------------------------------------
# Service-to-service URLs over the Railway private network.
# -----------------------------------------------------------------------------
CONVERSATION_CHAT_URL=http://conversation-chat.railway.internal:8082
TENANT_SERVICE_URL=http://tenant.railway.internal:8080
METRICAS_URL=http://compliance.railway.internal:8091
HOSPITAL_MOCK_URL=http://hospital-mock.railway.internal:8080
AGENT_RUNTIME_URL=http://agent-runtime.railway.internal:3100
AUTH_SERVICE_URL=http://tenant.railway.internal:8080
ACR_SERVICE_URL=http://agent-runtime.railway.internal:3100

# -----------------------------------------------------------------------------
# LLM model + endpoint.
# -----------------------------------------------------------------------------
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# -----------------------------------------------------------------------------
# CORS — apex domain on Cloudflare.
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGIN=https://YOUR_APEX

# -----------------------------------------------------------------------------
# Email defaults.
# -----------------------------------------------------------------------------
EMAIL_FROM_DEFAULT=noreply@YOUR_APEX
EMAIL_FROM_NAME=UNAgent Notifications
EMAIL_AUTH_STUB=false

# -----------------------------------------------------------------------------
# Telegram (optional).
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=default-tenant

# -----------------------------------------------------------------------------
# Twilio (not wired yet).
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_DEFAULT_TENANT_ID=default-tenant
