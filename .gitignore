# Local secrets — never commit
.env
.env.local
*.env.local
.env.dev
.env.prod

# Cloudflare Worker — local secrets only. wrangler.toml IS committed
# (contains no secrets — just URLs + bindings — and CI needs it to deploy).
cloudflare-worker/.dev.vars

# Stray wrangler state from invocations at the umbrella root
/.wrangler/
cloudflare-worker/node_modules/
cloudflare-worker/dist/
cloudflare-worker/.wrangler/
cloudflare-worker/worker-configuration.d.ts

# Editor noise
.vscode/
.idea/
*.swp

# OS noise
.DS_Store
