# Compliance & Metrics service (FastAPI).
# All variables are also overridable from the umbrella docker-compose env.
#
# Where to write the audit_logs collection. Defaults inside compose to the
# local email-mongo container. Point at Atlas if you want shared storage.
MONGO_URI=mongodb://localhost:27017

# Database name on the Mongo instance pointed to by MONGO_URI.
MONGO_DB_COMPLIANCE=UN_compliance_db
