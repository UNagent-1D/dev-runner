@startuml UNAgent_Deployment_Host
!theme plain
title **UNAgent — Deployment (2/2): Host-internal view**\nEverything inside the ""archsoft"" Docker network.\nColor coded for readability — maps 1:1 to the C&C view (§3.1).

skinparam shadowing false
skinparam roundCorner 12
skinparam defaultFontName "Inter, Helvetica, sans-serif"
skinparam defaultFontSize 12

' Estilos generales de componentes
skinparam NodeBackgroundColor #F0F4FF
skinparam NodeBorderColor #4A6FB5
skinparam ComponentBackgroundColor #FFF8E1
skinparam ComponentBorderColor #B89800
skinparam ArtifactBackgroundColor #F5F5F5
skinparam DatabaseBackgroundColor #FFF6E0
skinparam Style strictuml

' --- SEPARACIÓN MÁXIMA PARA EVITAR SUPERPOSICIÓN ---
skinparam linetype ortho
skinparam nodesep 100
skinparam ranksep 120

node "Host  ·  Docker engine 29 + containerd 2.2.3" <<device>> as host {

  ' --- BAND A: ingress / frontend ---
  together {
    component "**frontend**\nnginx 1.27 + Vite bundle\n3000 → 80" <<executionEnvironment>> as fe
    component "**chat-orch**\nRust / Axum\n8000 → 3000" <<executionEnvironment>> as orch
    component "**tenant**\nGo / Gin\n8080" <<executionEnvironment>> as tenant
  }

  ' --- BAND B: agent + conversation + compliance ---
  together {
    component "**agent-runtime**\nNode 20 / Express\n3100" <<executionEnvironment>> as agent
    component "**conversation-chat**\nGo / Gin\n8082" <<executionEnvironment>> as conv
    component "**compliance**\nPython / FastAPI\n8091" <<executionEnvironment>> as comp
  }

  ' --- BAND C: tools + email ---
  together {
    component "**hospital-mock**\nPython / Flask\n8092 → 8080" <<executionEnvironment>> as hosp
    component "**email-send**\nJava / Spring Boot 3.3\n8089 → 8080" <<executionEnvironment>> as email
    component "**grafana**\ngrafana-oss:11.6.0\n3001 → 3000" <<executionEnvironment>> as graf
  }

  ' --- BAND D: infrastructure ---
  together {
    component "**rabbitmq**\nrabbitmq:3-management\n5672 / 15672" <<executionEnvironment>> as rmq
    component "**hospital-postgres**\npostgres:16-alpine\n5432" <<executionEnvironment>> as hpg
    component "**email-mongo**\nmongo:7\n27017" <<executionEnvironment>> as emongo
  }

  ' --- BAND E: volumes ---
  together {
    artifact "hospital-postgres-data" as volH
    artifact "email-mongo-data" as volE
    artifact "grafana-data" as volG
  }
}

' ==========================================================
' Layout hints — Mantener estructura de la cuadricula
' ==========================================================
fe -[hidden]right-> orch
orch -[hidden]right-> tenant

agent -[hidden]right-> conv
conv -[hidden]right-> comp

hosp -[hidden]right-> email
email -[hidden]right-> graf

rmq -[hidden]right-> hpg
hpg -[hidden]right-> emongo

volH -[hidden]right-> volE
volE -[hidden]right-> volG

fe -[hidden]down-> agent
agent -[hidden]down-> hosp
hosp -[hidden]down-> rmq
rmq -[hidden]down-> volH

' ==========================================================
' Communication paths (solid) - COLORES Y TAMAÑOS VARIABLES
' Azul (#2E86C1) para HTTP
' Verde (#28B463) para TCP (Bases de datos)
' Naranja (#D68910) para AMQP
' ==========================================================
orch -[#2E86C1]up-> fe : <color:#2E86C1><<HTTP / SSE>></color>\n/v1/chat/stream
tenant -[#2E86C1]left-> fe : <color:#2E86C1><<HTTP>></color> /auth/login
comp -[#2E86C1]up-> fe : <color:#2E86C1><<HTTP>></color> /stats/*

orch -[#2E86C1]down-> agent : <color:#2E86C1><<HTTP>></color>\nsessions, turns
orch --[#2E86C1]down--> comp  : <color:#2E86C1><<HTTP>></color>\nrecord_turn, csat
orch -[#2E86C1]right-> tenant: <color:#2E86C1><<HTTP>></color>\nJWT validate
orch --[#2E86C1]down--> hosp  : <color:#2E86C1><<HTTP>></color>\ntool calls

agent -[#2E86C1]right-> conv : <color:#2E86C1><<HTTP>></color> proxy
agent -[#2E86C1]down-> hosp : <color:#2E86C1><<HTTP>></color>
agent --[#D68910]down--> rmq  : <color:#D68910><<AMQP>></color>

conv --[#D68910]down--> rmq   : <color:#D68910><<AMQP>></color> consume
conv --[#2E86C1]right--> email : <color:#2E86C1><<HTTP>></color>\nsend_confirmation_email\ntool dispatch

hosp -[#28B463]down-> hpg   : <color:#28B463><<TCP>></color> psycopg2
comp --[#28B463]down--> emongo : <color:#28B463><<TCP>></color> motor
email -[#28B463]down-> emongo : <color:#28B463><<TCP>></color> driver

' ==========================================================
' Lifecycle dependencies (dashed, light)
' Gris (#888888) para separar de la logica de negocio
' ==========================================================
hosp .[#888888]down.> hpg      : <color:#888888><<healthy>></color>
conv .[#888888]down.> rmq      : <color:#888888><<healthy>></color>
conv .[#888888]left.> agent    : <color:#888888><<started>></color>
agent .[#888888]down.> rmq     : <color:#888888><<healthy>></color>
agent .[#888888]down.> hosp    : <color:#888888><<started>></color>
orch .[#888888]down.> agent    : <color:#888888><<started>></color>
orch .[#888888]down.> conv     : <color:#888888><<started>></color>
orch .[#888888]down.> hosp     : <color:#888888><<started>></color>
fe .[#888888]right.> tenant   : <color:#888888><<healthy>></color>
fe .[#888888]down.> conv      : <color:#888888><<started>></color>
comp .[#888888]down.> emongo   : <color:#888888><<healthy>></color>
email .[#888888]down.> emongo  : <color:#888888><<healthy>></color>

' ==========================================================
' Persistence (dashed)
' ==========================================================
hpg .[#888888]down.> volH : <color:#888888><<persists>></color>
emongo .[#888888]down.> volE : <color:#888888><<persists>></color>
graf .[#888888]down.> volG : <color:#888888><<persists>></color>

' ==========================================================
' Cross-reference to the C&C view
' ==========================================================
note bottom of host
  **C&C ↔ Deployment mapping**
  Each container above is the **deployment artifact** of the
  matching component in the C&C view (§3.1):
  • `UN_chat_orch_ms`   → chat-orch              • `UN_email_send_ms`  → email-send
  • `UN_agent_runtime_ms` → agent-runtime         • `UN_compliance_ms`  → compliance
  • `UN_conversation-chat_ms` → conversation-chat  • `UN_tenant_ms`      → tenant
  • `UN_message_broker_mb` → rabbitmq             • `UN_fe`            → frontend (Pages in prod)
  • Hospital Mock         → hospital-mock         • `UN_*_db`          → hospital-postgres / email-mongo (+ Atlas / Supabase off-host)
  Connectors keep their roles: HTTP, SSE, long-poll, AMQP, DB_connector.
end note

@enduml
