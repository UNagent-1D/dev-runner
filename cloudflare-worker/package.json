{
  "name": "unagent-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker that serves the FrontEnd SPA and reverse-proxies API paths to Railway backends. Replaces the local nginx single-origin gateway.",
  "main": "src/index.ts",
  "scripts": {
    "typegen": "wrangler types",
    "typecheck": "wrangler types && tsc --noEmit",
    "dev": "wrangler dev --env dev",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env prod"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.114.0"
  }
}
